{
  "expo": {
    "scheme": "unmiser",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "bundler": "metro"
    },
    "name": "Unmiser",
    "slug": "unmiser",
    "version": "1.4.0",
    "plugins": [
      "expo-font",
      "expo-splash-screen",
      "expo-notifications",
      ["expo-local-authentication", { "faceIDPermission": "Unlock Unmiser with Face ID." }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "android": {
      "package": "com.vijayabaskar56.unmiser",
      "predictiveBackGestureEnabled": true,
      "versionCode": 412
    }
  }
}
