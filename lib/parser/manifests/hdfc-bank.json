{
  "$schema": "../manifest.schema.json",
  "notes": [
    "Patterns ported from the original Cashiro HDFCBankParser.kt (parser-core/src/main/kotlin/com/ritesh/parser/core/bank/HDFCBankParser.kt) plus formats observed in real device scans."
  ],
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "in.hdfc.bank",
    "type": "sms-parser",
    "name": "HDFC Bank",
    "country": "IN",
    "currency": "INR",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["HDFC", "HDFCBK", "HDFCBANK", "HDFCB"],
      "dltPatterns": [
        "^[A-Z]{2}-HDFCBK.*$",
        "^[A-Z]{2}-HDFC.*$",
        "^HDFC-[A-Z]+$",
        "^[A-Z]{2}-HDFCB.*$"
      ]
    },
    "filter": {
      "excludeKeywords": [
        "otp",
        "one time password",
        "verification code",
        "has requested",
        "payment request",
        "collect request",
        "ignore if already paid",
        "bill alert",
        "is due on",
        "will be debited",
        "will be deducted",
        "e-mandate",
        "offer",
        "discount",
        "win ",
        "card will be disabled",
        "invalid pin",
        "not credited",
        "txn declined",
        "transaction declined",
        "forex markup",
        "limit modified",
        "international merchant outlet",
        "activated:",
        "kyc consent",
        "validating the e-mail"
      ],
      "requireAnyKeyword": [
        "debited",
        "credited",
        "withdrawn",
        "deposited",
        "spent",
        "received",
        "transferred",
        "paid",
        "sent",
        "deducted",
        "charged",
        "txn"
      ]
    },
    "extract": {
      "amount": [
        {
          "re": "Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        },
        {
          "re": "INR\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        }
      ],
      "merchant": [
        {
          "re": "\\bTo\\s+(?<value>[^@\\n]*[A-Za-z][^@\\n]*?)@[^\\s]*\\s+On\\s+\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4}"
        },
        {
          "re": "\\bTo\\s+(?<value>[^@\\n]*[A-Za-z][^@\\n]*?)\\s+On\\s+\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4}"
        },
        {
          "re": "Info:\\s*(?:UPI/)?(?<value>[^/.\\n]+?)(?:/|\\.|$)"
        },
        {
          "re": "VPA\\s+[^@\\s]+@[^\\s]+\\s*\\((?<value>[^)]+)\\)"
        },
        {
          "re": "SALARY[- ](?<value>[^.\\n]+?)(?:\\s+Info|$)"
        },
        {
          "re": "at\\s+(?<value>[^.\\n]+?)(?:\\s+by\\s+|\\s+on\\s+|\\.|$)"
        }
      ],
      "balance": [
        {
          "re": "Avl\\s+bal:?\\s*INR\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        },
        {
          "re": "Available\\s+Balance:?\\s*INR\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        },
        {
          "re": "Bal\\s+Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        }
      ],
      "reference": [
        {
          "re": "UPI\\s+Ref\\s+No\\.?\\s*(?<value>\\d{9,})"
        },
        {
          "re": "\\bRef\\s*(?:No)?[:\\s]+(?<value>[A-Z0-9]+)"
        }
      ],
      "accountLast4": [
        {
          "re": "A/c\\s+(?:[X*]+\\s*)?(?<value>\\d+)",
          "takeLast4": true
        },
        {
          "re": "Card\\s+x(?<value>\\d{4})",
          "takeLast4": true
        },
        {
          "re": "BLOCK\\s+DC\\s+(?<value>\\d{4})",
          "takeLast4": true
        },
        {
          "re": "HDFC\\s+Bank\\s+[X*]*(?<value>\\d{4,})",
          "takeLast4": true
        }
      ]
    },
    "typeRules": {
      "investment": ["iccl", "nsccl", "groww", "zerodha", "sip", "mutual fund"],
      "credit": ["block cc", "block pcc", "spent on card"],
      "expense": ["debited", "withdrawn", "spent", "charged", "paid", "sent", "deducted", "txn"],
      "income": ["credited", "deposited", "received", "refund"]
    },
    "cardRules": {
      "includeKeywords": ["credit card", "debit card", "card x", "block cc", "block pcc"],
      "excludeKeywords": ["a/c", "account", "hdfc bank a/c"]
    },
    "cleaning": {
      "stripPatterns": [
        "\\s+Ref\\s+No.*$",
        "\\s+UPI.*$",
        "\\s+PVT\\.?\\s+LTD\\.?$",
        "\\s+LTD\\.?$"
      ],
      "minMerchantLength": 2,
      "commonWords": ["USING", "VIA", "THROUGH", "TO", "FROM"]
    },
    "mandate": {
      "detectKeyword": "E-Mandate!",
      "amount": "Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)\\s+will\\s+be\\s+deducted",
      "date": "deducted\\s+on\\s+(?<value>\\d{2}/\\d{2}/\\d{2}),?\\s*\\d{2}:\\d{2}:\\d{2}",
      "merchant": "For\\s+(?<value>[^\\n]+?)\\s+mandate",
      "umn": "UMN\\s+(?<value>[a-zA-Z0-9@]+)",
      "dateFormat": "dd/MM/yy"
    },
    "pipeline": [
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAll": ["Sent Rs", "From HDFC Bank"]
        },
        "field": "transactionType",
        "value": "EXPENSE"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAll": ["Sent Rs", "From HDFC Bank", "@"]
        },
        "field": "merchant",
        "value": "UPI Payee"
      },
      {
        "kind": "extractFieldWhen",
        "when": {
          "containsAll": ["Sent Rs", "From HDFC Bank", "@"]
        },
        "field": "merchant",
        "extractors": [
          {
            "re": "\\bTo\\s+(?<value>[^@\\n]*[A-Za-z][^@\\n]*?)@[^\\s]*\\s+On\\s+\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4}"
          }
        ]
      },
      {
        "kind": "fallbackField",
        "field": "merchant",
        "value": "ATM"
      }
    ]
  },
  "fixtures": [
    {
      "name": "e-mandate subscription notice",
      "sender": "VM-HDFCBK-S",
      "receivedAt": "2026-06-09T10:00:00.000Z",
      "body": "E-Mandate! Rs.1,499 will be deducted on 15/07/26, 09:00:00 For NETFLIX mandate UMN HDFCUMN12345",
      "expected": {
        "confidence": "HIGH",
        "reasons": ["MANDATE_DETECTED"],
        "mandate": {
          "amount": "1499",
          "nextDeductionDate": "2026-07-15",
          "merchant": "NETFLIX",
          "umn": "HDFCUMN12345",
          "currency": "INR",
          "pluginId": "in.hdfc.bank"
        }
      }
    },
    {
      "name": "e-mandate missing date goes to review",
      "sender": "VM-HDFCBK-S",
      "receivedAt": "2026-06-09T10:00:00.000Z",
      "body": "E-Mandate! Rs.1,499 will be deducted soon For NETFLIX mandate UMN HDFCUMN12345",
      "expected": {
        "confidence": "REVIEW",
        "reasons": ["MANDATE_DETECTED"],
        "mandateParseFailed": true
      }
    },
    {
      "name": "upi sent format",
      "sender": "VM-HDFCBK-S",
      "receivedAt": "2026-06-09T10:05:00.000Z",
      "body": "Sent Rs.250.00 From HDFC Bank A/C *1234 To tea stall@upi On 09/06/26 Ref 987654.",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "250.00",
          "merchant": "tea stall",
          "accountLast4": "1234",
          "transactionType": "EXPENSE",
          "reference": "987654"
        }
      }
    },
    {
      "name": "balance debit",
      "sender": "VM-HDFCBK-S",
      "receivedAt": "2026-06-09T10:06:00.000Z",
      "body": "Rs.1250.00 debited from HDFC Bank A/c XX1234 at AMAZON on 09/06/26. Avl bal:INR 88,750.20",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "1250.00",
          "merchant": "AMAZON",
          "balance": "88750.20",
          "accountLast4": "1234",
          "transactionType": "EXPENSE"
        }
      }
    },
    {
      "name": "upi sent lowercase-x account with payee name and Not You suffix",
      "sender": "VM-HDFCBK-S",
      "receivedAt": "2026-06-09T10:07:00.000Z",
      "body": "Sent Rs.36.00 From HDFC Bank A/C x9012 To Corner Coffee Bar On 24/12/24 Ref 435959487717 Not You? Call 18002586161/SMS BLOCK UPI to 7308080808",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "36.00",
          "merchant": "Corner Coffee Bar",
          "accountLast4": "9012",
          "transactionType": "EXPENSE",
          "reference": "435959487717"
        }
      }
    },
    {
      "name": "cheque debit update with Info merchant and no A/c prefix",
      "sender": "VM-HDFCBN-S",
      "receivedAt": "2026-06-09T10:08:00.000Z",
      "body": "UPDATE: INR 2,00,000.00 debited from HDFC Bank XX9012 on 12-DEC-24. Info: SELF - CHQ PAID - CITY ROAD. Avl bal:INR 8,935.00",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "200000.00",
          "accountLast4": "9012",
          "transactionType": "EXPENSE",
          "balance": "8935.00"
        }
      }
    },
    {
      "name": "upi debit from A/c with UPI Ref No in parentheses",
      "sender": "CP-HDFCBK-S",
      "receivedAt": "2026-06-09T10:10:00.000Z",
      "body": "Rs.500.00 debited from A/c XX1234 on 20-Oct-25 to merchant@upi (UPI Ref No 123456789012)",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "500.00",
          "accountLast4": "1234",
          "transactionType": "EXPENSE",
          "reference": "123456789012"
        }
      }
    },
    {
      "name": "sent upi to named payee multi-line no @",
      "sender": "JD-HDFCBK-S",
      "receivedAt": "2026-06-09T10:11:00.000Z",
      "body": "Sent Rs.45.00\nFrom HDFC Bank A/C *1234\nTo Sample Friend\nOn 23/05/26\nRef 123456789012\nNot You?\nContact bank support/SMS BLOCK UPI",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "45.00",
          "merchant": "Sample Friend",
          "accountLast4": "1234",
          "transactionType": "EXPENSE",
          "reference": "123456789012"
        }
      }
    },
    {
      "name": "sent upi to numeric vpa yields UPI Payee",
      "sender": "AD-HDFCBK-S",
      "receivedAt": "2026-06-09T10:12:00.000Z",
      "body": "Sent Rs.70.00\nFrom HDFC Bank A/C *1234\nTo 0000000000@bank\nOn 23/05/26\nRef 123456789013\nNot You?\nContact bank support/SMS BLOCK UPI",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "70.00",
          "merchant": "UPI Payee",
          "accountLast4": "1234",
          "transactionType": "EXPENSE",
          "reference": "123456789013"
        }
      }
    },
    {
      "name": "bill alert reminder should not parse",
      "sender": "CP-HDFCBK-S",
      "receivedAt": "2026-06-09T10:13:00.000Z",
      "body": "New Bill Alert:\nYour AUBA00000NAT3Q Bill 8078064625 of Rs.3953.72 is due on 05-Nov-2025. To pay, login to HDFC Bank Net/Mobile Banking>BillPay\nT&C. Ignore if paid",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    },
    {
      "name": "txn declined notice is filter-rejected",
      "sender": "VM-HDFCBK-S",
      "receivedAt": "2025-11-30T20:33:47.000Z",
      "body": "TXN DECLINED: Rs. 3000.00 on 30-11-25 at 20:33:47 On HDFC Bank Debit Card 7087 Reason: Insufficient limit",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    },
    {
      "name": "forex markup advisory is filter-rejected",
      "sender": "AD-HDFCBK-S",
      "receivedAt": "2025-12-01T09:00:00.000Z",
      "body": "Notice! Forex Markup fee applies to your HDFC Bank Debit Card International payment. T&C apply.",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    }
  ]
}
