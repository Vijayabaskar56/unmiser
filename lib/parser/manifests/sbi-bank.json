{
  "$schema": "../manifest.schema.json",
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "in.sbi.bank",
    "type": "sms-parser",
    "name": "State Bank of India",
    "country": "IN",
    "currency": "INR",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["SBI", "SBIBK", "SBICRD", "ATMSBI"],
      "dltPatterns": ["^[A-Z]{2}-SBIBK.*$", "^[A-Z]{2}-SBI.*$", ".*CBSSBI.*", ".*SBIPSG.*"]
    },
    "filter": {
      "excludeKeywords": ["otp", "one time password", "offer", "minimum amount due"],
      "requireAnyKeyword": ["debited", "credited", "debit", "credit", "spent", "withdrawn"]
    },
    "extract": {
      "amount": [
        {
          "re": "has\\s+credit\\s+for\\s+[^.\\n]+?\\s+of\\s+(?:Rs\\.?|INR)\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        },
        {
          "re": "has\\s+a\\s+credit\\s+by\\s+[^.\\n]+?\\s+of\\s+(?:Rs\\.?|INR)\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        },
        {
          "re": "has\\s+a\\s+debit\\s+by\\s+transfer\\s+of\\s+(?:Rs\\.?|INR)\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        },
        {
          "re": "Credited\\s+(?:Rs\\.?|INR)\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        },
        {
          "re": "(?:Rs\\.?|INR)\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)\\s+spent"
        },
        {
          "re": "(?:Rs\\.?|INR)\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        }
      ],
      "merchant": [
        {
          "re": "done\\s+at\\s+(?<value>[^.\\n]+?)(?:\\s+on\\s+|$)"
        },
        {
          "re": "has\\s+credit\\s+for\\s+(?<value>[^.\\n]+?)\\s+of"
        },
        {
          "re": "has\\s+a\\s+credit\\s+by\\s+(?<value>[^.\\n]+?)\\s+of"
        },
        {
          "re": "on\\s+\\d{2}/\\d{2}/\\d{2,4}\\s*-\\s*(?<value>[^.\\n]+)"
        },
        {
          "re": "trf\\s+to\\s+(?<value>[^.\\n]+?)(?:\\s+Ref|$)"
        }
      ],
      "balance": [
        {
          "re": "Avl\\s+Bal\\s+(?:Rs\\.?|INR)\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        },
        {
          "re": "updated\\s+available\\s+balance\\s+is\\s+(?:Rs\\.?|INR)\\s*(?<value>[0-9,]+(?:\\.\\d{1,2})?)"
        }
      ],
      "reference": [
        {
          "re": "(?:Ref\\s+No\\.?|transaction\\s+number)\\s*(?<value>[A-Z0-9-]+)"
        }
      ],
      "accountLast4": [
        {
          "re": "SBI\\s+Debit\\s+Card\\s+(?<value>[\\w-]+)",
          "takeLast4": true
        },
        {
          "re": "A/?C\\s+(?:no\\.?\\s+)?[X*]*(?<value>\\d+)",
          "takeLast4": true
        }
      ]
    },
    "typeRules": {
      "expense": [
        "debited for",
        "is debited",
        "withdrawn",
        "transferred",
        "by sbi debit card",
        "debit",
        "paid to",
        "spent"
      ],
      "income": ["credited", "has credit for", "has a credit by", "credit by", "received transfer"]
    },
    "cardRules": {
      "includeKeywords": ["sbi debit card", "credit card", "card ending"],
      "excludeKeywords": ["a/c", "account"]
    },
    "cleaning": {
      "stripPatterns": ["\\s+Ref.*$", "\\s+on\\s+\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4}.*$"],
      "minMerchantLength": 2
    },
    "pipeline": [
      {
        "kind": "setFieldWhen",
        "when": {
          "senderContainsAny": ["SBICRD"],
          "containsAny": ["spent on"]
        },
        "field": "transactionType",
        "value": "CREDIT"
      },
      {
        "kind": "fallbackField",
        "field": "merchant",
        "value": "SBI Transaction"
      }
    ]
  },
  "fixtures": [
    {
      "name": "account credit",
      "sender": "JD-CBSSBI",
      "receivedAt": "2026-06-09T10:10:00.000Z",
      "body": "Your A/C XXXXX314502 has credit for BY SALARY of Rs 10,700.00 on 02/05/22. Avl Bal Rs 13,50,000.00.-SBI",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "10700.00",
          "merchant": "BY SALARY",
          "balance": "1350000.00",
          "accountLast4": "4502",
          "transactionType": "INCOME"
        }
      }
    },
    {
      "name": "debit card spend",
      "sender": "ATMSBI",
      "receivedAt": "2026-06-09T10:12:00.000Z",
      "body": "Dear Customer, transaction number 1234 for Rs.383.00 by SBI Debit Card 0000 done at merchant on 13Sep25. Your updated available balance is Rs.999999999.",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "383.00",
          "merchant": "merchant",
          "reference": "1234",
          "accountLast4": "0000",
          "transactionType": "EXPENSE",
          "isFromCard": true
        }
      }
    },
    {
      "name": "credit by Cheque",
      "sender": "AD-CBSSBI",
      "receivedAt": "2026-06-09T10:14:00.000Z",
      "body": "Dear Customer, Your A/C XXXXX314567 has a credit by Cheque of Rs 12,07,000.00 on 07/10/22. Avl Bal Rs 18,06,500.00.-SBI",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "1207000.00",
          "merchant": "Cheque",
          "accountLast4": "4567",
          "transactionType": "INCOME",
          "balance": "1806500.00"
        }
      }
    },
    {
      "name": "credited INR with reverse ATM suffix",
      "sender": "AD-CBSSBI",
      "receivedAt": "2026-06-09T10:16:00.000Z",
      "body": "Your AC XXXXX314567 Credited INR 9,000.00 on 22/05/22 -REVERSE ATM WDL. Avl Bal INR 13,08,900.00.-SBI",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "9000.00",
          "merchant": "REVERSE ATM WDL",
          "accountLast4": "4567",
          "transactionType": "INCOME",
          "balance": "1308900.00"
        }
      }
    },
    {
      "name": "debit by transfer",
      "sender": "AD-CBSSBI-S",
      "receivedAt": "2026-06-09T10:18:00.000Z",
      "body": "Dear Customer, Your A/C XXXXX901234 has a debit by transfer of Rs 230.00 on 18/09/25. Avl Bal Rs 6,500.00.-SBI",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "230.00",
          "accountLast4": "1234",
          "transactionType": "EXPENSE",
          "balance": "6500.00"
        }
      }
    },
    {
      "name": "issue #35 debit with credited destination (a/c no. form)",
      "sender": "VA-SBIPSG-T",
      "receivedAt": "2026-06-09T10:20:00.000Z",
      "body": "Dear Customer, Your a/c no. XXXXXXXX5045 is debited for Rs.500.00 on 31-03-26 and a/c XXXXXXX418 credited (IMPS Ref no ---------------). -SBI",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "500.00",
          "accountLast4": "5045",
          "transactionType": "EXPENSE"
        }
      }
    },
    {
      "name": "terse debited from a/c",
      "sender": "ATMSBI",
      "receivedAt": "2026-06-09T10:22:00.000Z",
      "body": "Rs.500 debited from A/c X1234 on 13Sep25. Avl Bal Rs.999999999",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "500",
          "accountLast4": "1234",
          "transactionType": "EXPENSE"
        }
      }
    }
  ]
}
